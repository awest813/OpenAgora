{
  "id": "upzoning_incentives",
  "label": "Upzoning Incentives",
  "description": "Allows higher-density residential development. Increases housing supply but may spike land value and push up rents in the short term.",
  "category": "housing",
  "type": "zone_modifier",
  "cost_per_month": 200,
  "min_approval": 30,
  "exclusive_with": ["rent_control"],
  "levels": [
    {
      "level": 1,
      "cost_per_month": 200,
      "effects": [
        { "target": "zoneDensityGrowthRate", "op": "multiply", "value": 1.20 },
        { "target": "landValueProxy", "op": "multiply", "value": 1.08 }
      ]
    },
    {
      "level": 2,
      "cost_per_month": 450,
      "unlock_min_approval": 55,
      "effects": [
        { "target": "zoneDensityGrowthRate", "op": "multiply", "value": 1.40 },
        { "target": "landValueProxy", "op": "multiply", "value": 1.15 },
        { "target": "businessConfidence", "op": "add", "value": 6.0 }
      ]
    }
  ],
  "ui_slider": { "min": 0, "max": 1, "step": 1 }
}
