{
  "id": "rent_strike",
  "trigger": { "index": "affordabilityIndex", "op": "lt", "value": 30 },
  "cooldown_months": 6,
  "notification": "Tenants have gone on rent strike in the warehouse district. Tax revenues are falling.",
  "effects": [
    { "target": "taxEfficiency", "op": "multiply", "value": 0.80 },
    { "target": "publicTrust",   "op": "add",      "value": -8.0 }
  ]
}
